# Neon Postgres — server-side only (never expose in Vite client code)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: API port for local dev server (default 8787)
# API_PORT=8787

# Optional: if API is hosted elsewhere (e.g. Bid Studio backend)
# VITE_API_URL=https://your-app.com
